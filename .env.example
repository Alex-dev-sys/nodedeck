NODE_ENV=production
HOST=127.0.0.1
PORT=8787
CORS_ORIGIN=http://127.0.0.1:8080
DATABASE_URL=postgresql://infra:replace-with-postgres-password@postgres:5432/infra_dashboard
DATABASE_POOL_MAX=10
DATABASE_SSL=false
# Generate a unique value with at least 32 characters before deploying.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
COOKIE_SECURE=false
LOCAL_AUTH_BYPASS=false
HOST_ALERT_THRESHOLD=90
# Required by the Vercel cron endpoint; generate at least 32 random characters.
CRON_SECRET=replace-with-a-long-random-cron-secret
POSTGRES_PASSWORD=replace-with-a-long-random-password
BOOTSTRAP_EMAIL=owner@example.com
BOOTSTRAP_PASSWORD=replace-this-before-seeding
WEB_PORT=8080
